 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Custom Phase Profile with PhaseInteractionModel\\n",
    "This notebook demonstrates how to create a custom phase profile by subclassing `BasePhase`. This allows for the implementation of arbitrary phase functions on a surface. We will create a simple system with a surface that has a radially varying phase profile and observe its effect on traced rays."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from optiland import optic, phase_profiles\\n",
    "import optiland.backend as be"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class RadialPhase(phase_profiles.BasePhase):\\n",
    "    def __init__(self, coefficient):\\n",
    "        super().__init__()\\n",
    "        self.coefficient = coefficient\\n",
    "    def _calculate_phase(self, x, y):\\n",
    "        r_sq = x**2 + y**2\\n",
    "        return self.coefficient * r_sq\\n",
    "class CustomPhaseSystem(optic.Optic):\\n",
    "    def __init__(self):\\n",
    "        super().__init__()\\n",
    "        # Surface 0: Object plane\\n",
    "        self.add_surface(index=0, z=0)\\n",
    "        # Surface 1: Custom phase surface\\n",
    "        custom_phase = RadialPhase(coefficient=1e-3) # Small coefficient for radial phase\\n",
    "        self.add_surface(\\n",
    "            index=1,\\n",
    "            z=50,\\n",
    "            phase_model=custom_phase,\\n",
    "            is_stop=True\\n",
    "        )\\n",
    "        # Surface 2: Image plane\\n",
    "        self.add_surface(index=2, z=100)\\n",
    "        # System aperture and field\\n",
    "        self.set_aperture(aperture_type=\\"EPD\\", value=20)\\n",
    "        self.set_field_type(field_type=\\"object_height\\")\\n",
    "        self.add_field(y=0)\\n",
    "        # Wavelength\\n",
    "        self.add_wavelength(value=0.550, is_primary=True)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "tags": [
     "nbsphinx-thumbnail"
    ]
   },
   "outputs": [],
   "source": [
    "lens = CustomPhaseSystem()\\n",
    "_ = lens.draw(num_rays=11, figsize=(6, 6))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "The plot shows that the rays are bent by the custom phase surface. The radial phase profile acts like a lens, causing the rays to converge. This demonstrates the flexibility of the `PhaseInteractionModel` for creating complex optical elements."
   ]
  }
 ],
