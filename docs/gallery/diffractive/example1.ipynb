{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Simple Grating with PhaseInteractionModel\\n",
    "This notebook demonstrates how to create a simple diffraction grating using the `PhaseInteractionModel` and `GratingPhase` in Optiland. We will set up a simple optical system with a single surface that acts as a grating and trace some rays through it to observe the diffraction."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from optiland import optic, phase_profiles\\n",
    "import optiland.backend as be"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class SimpleGratingSystem(optic.Optic):\\n",
    "    def __init__(self):\\n",
    "        super().__init__()\\n",
    "        # Surface 0: Object plane\\n",
    "        self.add_surface(index=0, z=0)\\n",
    "        # Surface 1: Grating surface\\n",
    "        grating = phase_profiles.GratingPhase(period=2.5, order=1) # 2.5 um period, 1st order\\n",
    "        self.add_surface(\\n",
    "            index=1,\\n",
    "            z=50,\\n",
    "            phase_model=grating,\\n",
    "            is_stop=True\\n",
    "        )\\n",
    "        # Surface 2: Image plane\\n",
    "        self.add_surface(index=2, z=100)\\n",
    "        # System aperture and field\\n",
    "        self.set_aperture(aperture_type=\\"EPD\\", value=20)\\n",
    "        self.set_field_type(field_type=\\"object_height\\")\\n",
    "        self.add_field(y=0)\\n",
    "        # Wavelengths\\n",
    "        self.add_wavelength(value=0.550, is_primary=True) # Green\\n",
    "        self.add_wavelength(value=0.450) # Blue\\n",
    "        self.add_wavelength(value=0.650) # Red"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "tags": [
     "nbsphinx-thumbnail"
    ]
   },
   "outputs": [],
   "source": [
    "lens = SimpleGratingSystem()\\n",
    "_ = lens.draw(num_rays=5, wavelengths=[0.450, 0.550, 0.650], figsize=(6, 6))"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "As you can see in the plot, the different wavelengths are diffracted at different angles by the grating surface, demonstrating the dispersive effect of the grating."
   ]
  }
 ],
